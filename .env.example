# Simple MLOps local runtime defaults.
#
# This file contains only local application settings. Copy Grafana Cloud
# settings from .env.grafanacloud.example into your private .env when you want
# to send logs, metrics, traces, or import dashboards.

APP_CONFIG_PATH=/app/config/app.local.json
OTLP_TRACES_ENDPOINT=http://alloy:4318/v1/traces
