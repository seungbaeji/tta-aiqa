{
  "uid": "ai-quality-overview",
  "title": "AI Quality Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "templating": {
    "list": [
      {
        "name": "metrics_datasource",
        "label": "Metrics datasource",
        "type": "datasource",
        "query": "prometheus",
        "regex": "",
        "hide": 0,
        "current": {
          "text": "grafanacloud-prom",
          "value": "grafanacloud-prom",
          "selected": true
        }
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Count",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_request_total"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Count",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_error_total"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 6,
        "y": 0
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Average Latency",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_latency_average_ms"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 12,
        "y": 0
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "High Risk Rate",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_high_risk_rate"
        }
      ],
      "gridPos": {
        "h": 6,
        "w": 6,
        "x": 18,
        "y": 0
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Service Reliability Trend",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_error_total",
          "legendFormat": "Errors"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_validation_failure_total",
          "legendFormat": "Validation Failures"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 6
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Score and Prediction Trend",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_score_average",
          "legendFormat": "Average Score"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_valid_score_average",
          "legendFormat": "Valid Average Score"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_high_risk_rate",
          "legendFormat": "High Risk Rate"
        },
        {
          "refId": "D",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_valid_high_risk_rate",
          "legendFormat": "Valid High Risk Rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 6
      }
    },
    {
      "id": 7,
      "type": "barchart",
      "title": "Prediction Distribution",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_prediction_count",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "scope",
            "rowField": "prediction",
            "cellField": "Value"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 75,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xField": "prediction",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 6
      }
    },
    {
      "id": 8,
      "type": "barchart",
      "title": "Score Bucket Distribution",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_score_bucket_count",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "scope",
            "rowField": "bucket",
            "cellField": "Value"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 75,
            "lineWidth": 1
          }
        },
        "overrides": []
      },
      "options": {
        "orientation": "vertical",
        "xField": "bucket",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 14
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Input Drift Delta Trend",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_input_mean_delta",
          "legendFormat": "{{feature}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "barAlignment": 0,
            "lineWidth": 1,
            "fillOpacity": 10,
            "showPoints": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 8,
        "y": 14
      }
    },
    {
      "id": 10,
      "type": "barchart",
      "title": "Heart Rate Distribution: Reference vs Current",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_input_histogram_count{feature=\"heart_rate\"}",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "scope",
            "rowField": "bucket",
            "cellField": "Value"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 75,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "baseline"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "current"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "xField": "bucket",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 22
      }
    },
    {
      "id": 11,
      "type": "barchart",
      "title": "Oxygen Saturation Distribution: Reference vs Current",
      "datasource": {
        "type": "prometheus",
        "uid": "${metrics_datasource}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${metrics_datasource}"
          },
          "expr": "ai_quality_input_histogram_count{feature=\"oxygen_saturation\"}",
          "format": "table",
          "instant": true,
          "range": false
        }
      ],
      "transformations": [
        {
          "id": "groupingToMatrix",
          "options": {
            "columnField": "scope",
            "rowField": "bucket",
            "cellField": "Value"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 75,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "baseline"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "blue"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "current"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "orange"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "orientation": "vertical",
        "xField": "bucket",
        "stacking": "none",
        "groupWidth": 0.7,
        "barWidth": 0.9,
        "showValue": "auto",
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 22
      }
    }
  ]
}