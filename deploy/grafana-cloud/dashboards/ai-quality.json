      "id": 4,
      "targets": [{"expr": "sum by (model_profile, model_version) (rate(aiqa_risk_predictions_total{environment=~\"$environment\",prediction=\"high_risk\"}[$__rate_interval])) / clamp_min(sum by (model_profile, model_version) (rate(aiqa_risk_predictions_total{environment=~\"$environment\"}[$__rate_interval])), 1e-9)", "refId": "A"}],
      "title": "Positive mortality-risk rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "__AIQA_METRICS_UID__"},
