      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "id": 1,
      "targets": [{"expr": "sum by (status_code) (rate(aiqa_risk_requests_total{environment=~\"$environment\"}[$__rate_interval]))", "refId": "A"}],
      "title": "Request rate",
