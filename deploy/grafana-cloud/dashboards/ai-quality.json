    },
    {
      "datasource": {"type": "prometheus", "uid": "__AIQA_METRICS_UID__"},
      "fieldConfig": {"defaults": {"unit": "percentunit"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "targets": [{"expr": "sum(rate(aiqa_risk_requests_total{environment=~\"$environment\",status_code=~\"5..\"}[$__rate_interval])) / clamp_min(sum(rate(aiqa_risk_requests_total{environment=~\"$environment\"}[$__rate_interval])), 1e-9)", "refId": "A"}],
      "title": "Error rate",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "__AIQA_METRICS_UID__"},
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le) (rate(aiqa_risk_request_duration_seconds_bucket{environment=~\"$environment\"}[$__rate_interval])))", "refId": "A"}],
      "title": "P95 latency",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "__AIQA_METRICS_UID__"},
