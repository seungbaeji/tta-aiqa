      "id": 5,
      "targets": [{"expr": "histogram_quantile(0.95, sum by (le, model_profile, model_version) (rate(aiqa_risk_score_bucket{environment=~\"$environment\"}[$__rate_interval])))", "refId": "A"}],
      "title": "Risk score P95",
      "type": "timeseries"
    },
    {
